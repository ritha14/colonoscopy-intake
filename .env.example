# Copy this file to .env and fill in your values
# Never commit .env to git

# Email / SMTP settings
# For Gmail: use an App Password (not your regular password)
# Settings > Security > 2-Step Verification > App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@houstoncommunitysurgical.com
SMTP_PASSWORD=your_app_password_here
FROM_EMAIL=info@houstoncommunitysurgical.com
OFFICE_EMAIL=info@houstoncommunitysurgical.com

# Anthropic API key (for ASA classification)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# YouTube video ID (just the ID, not the full URL)
# e.g. if video URL is https://www.youtube.com/watch?v=abc123 then use: abc123
YOUTUBE_VIDEO_ID=
